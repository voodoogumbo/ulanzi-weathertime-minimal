/*
  config.h.example - Template configuration file for TC001 Enhanced Clock

  SETUP INSTRUCTIONS:
  1. Copy this file to 'config.h' in the same directory
  2. Fill in your actual values below
  3. Never commit the real config.h file to public repositories!

  MQTT Topics (automatically created):
  - {MQTT_BASE}/time        - REQUIRED: Time sync: {"unix_time":1640995200}
  - {MQTT_BASE}/notify      - Show notification: {"text":"Hello", "color":"FF0000", "speed":80, "repeat":2}
  - {MQTT_BASE}/page        - Change page: {"page":"clock|weather"}
  - {MQTT_BASE}/config      - Runtime config: {"page_duration":10, "rotation_enabled":true}
  - {MQTT_BASE}/weather     - Force weather update: {}
*/

#ifndef CONFIG_H
#define CONFIG_H

/*********** WIFI CONFIGURATION ***********/
#define WIFI_SSID       "YourWiFiNetworkName"
#define WIFI_PASSWORD   "YourWiFiPassword"

/*********** MQTT CONFIGURATION ***********/
#define MQTT_HOST       "192.168.1.100"
#define MQTT_PORT       1883
#define MQTT_BASE       "tc001"
#define MQTT_USER       ""          // leave empty for anonymous
#define MQTT_PASS       ""          // leave empty for anonymous

/*********** MQTT TLS CONFIGURATION ***********/
// Set to 1 to enable TLS encryption for MQTT traffic
// When enabled, uses WiFiClientSecure instead of WiFiClient
#define MQTT_USE_TLS    0
// REQUIRED when TLS enabled: PEM-encoded CA certificate for broker verification
// Paste your CA cert as a multi-line C string literal (see config.h for format)
#define MQTT_CA_CERT    ""  // REQUIRED: paste your CA cert PEM here

/*********** OTA CONFIGURATION ***********/
#define OTA_PASSWORD    "your_ota_password"

/*********** OPENWEATHER API CONFIGURATION ***********/
// Get your free API key from: https://openweathermap.org/api
#define OPENWEATHER_API_KEY "your_openweather_api_key_here"
// Your location coordinates (get from https://www.latlong.net/)
#define OPENWEATHER_LAT "40.7128"
#define OPENWEATHER_LON "-74.0060"

#endif // CONFIG_H
